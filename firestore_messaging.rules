rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Controlla che l'utente abbia effettuato l'accesso
    function isAuthenticated() {
      return request.auth != null;
    }

    // Ottiene l'UUID dell'utente dalla mappatura firebaseUid -> uuid
    // Restituisce null se la mappatura non esiste ancora (evita errore su get())
    function getUserUuid() {
      let mappingDoc = /databases/$(database)/documents/userMappings/$(request.auth.uid);
      return exists(mappingDoc) ? get(mappingDoc).data.uuid : null;
    }

    // Mappatura firebaseUid -> uuid. Ogni utente può creare/leggere solo il proprio documento.
    match /userMappings/{odFirebaseUid} {
      allow read: if isAuthenticated() && request.auth.uid == odFirebaseUid;
      allow create, update, delete: if isAuthenticated() && request.auth.uid == odFirebaseUid;
    }

    // Ban records — any authenticated user can read (needed for getOrCreateConversation check)
    // and write (to ban a sender after delete & ban action).
    match /bans/{bannedUserId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /conversations/{conversationId} {
      // Controlla che gli aggiornamenti non modifichino lo stato del filtro AI
      function isNotUpdatingFilter() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isFiltered', 'filterReason', 'filterCheckedAt']);
      }

      // Permette solo l'operazione di "unfilter" (isFiltered: true → false).
      // I partecipanti possono segnare una conversazione come non-spam, ma non possono filtrarla.
      function isUnfilteringConversation() {
        return resource.data.isFiltered == true &&
               request.resource.data.isFiltered == false;
      }

      // Per leggere l'UUID dell'utente deve essere nei participantIds
      allow read: if isAuthenticated() && getUserUuid() in resource.data.participantIds;

      // Per aggiornare: l'UUID deve essere nei participantIds e
      // l'update non deve toccare i campi filtro, OPPURE sta eseguendo un unfilter (not spam).
      allow update: if isAuthenticated() && getUserUuid() in resource.data.participantIds &&
                    (isNotUpdatingFilter() || isUnfilteringConversation());
      
      // Eliminazione della conversazione
      allow delete: if isAuthenticated() && getUserUuid() in resource.data.participantIds;

      // Per creare, l'utente deve mettersi nei participantIds. Un utente normale non può creare conversazioni filtrate in partenza.
      allow create: if isAuthenticated() && getUserUuid() in request.resource.data.participantIds &&
                    (!request.resource.data.keys().hasAny(['isFiltered']) || request.resource.data.isFiltered == false);

      match /messages/{messageId} {
        // Ottieni i participantIds della conversazione padre una volta sola
        function isParticipant() {
          return isAuthenticated() &&
            getUserUuid() in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }

        // Verifica che un update riguardi solo i campi consentiti ai partecipanti:
        // readBy, deliveredTo (ricevuti dal destinatario), e nessun altro campo
        function isReceiptUpdate() {
          let allowed = ['readBy', 'deliveredTo'];
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
        }

        // Lettura: qualsiasi partecipante può leggere i messaggi
        allow read: if isParticipant();

        // Creazione: solo i partecipanti possono inviare messaggi, e un utente non può creare "system messages"
        allow create: if isParticipant() && 
                      (!request.resource.data.keys().hasAny(['isSystemMessage']) || request.resource.data.isSystemMessage == false);

        // Update: i partecipanti possono aggiornare solo readBy e deliveredTo
        allow update: if isParticipant() && isReceiptUpdate();

        // Delete: solo i partecipanti possono eliminare messaggi (es. cancel upload)
        allow delete: if isParticipant();
      }
    }
  }
}
