rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Constraints for images (max 5MB, image/* content type)
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') 
             && request.resource.size < 5 * 1024 * 1024;
    }
    
    // Constraints for documents (max 10MB, allowlisted content types)
    function isValidDocument() {
      return request.resource.size < 10 * 1024 * 1024
             && (request.resource.contentType.matches('application/pdf')
              || request.resource.contentType.matches('application/msword')
              || request.resource.contentType.matches('application/vnd\\.openxmlformats.*')
              || request.resource.contentType.matches('text/plain'));
    }

    // 1. Profile Pictures
    // Users can only upload/modify their own profile picture.
    // Anyone authenticated can view profile pictures.
    match /profile_images/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() 
                   && isValidImage()
                   && fileName == request.auth.uid + ".jpg";
    }
    
    // 2. Chat Images
    // Read: open to all authenticated users.
    // Known limitation: Storage rules cannot query Firestore, so we cannot verify
    // that the reader is a participant of the conversation at the rules layer.
    // Mitigation: file paths use unguessable UUIDs, and download URLs are only
    // shared within the conversation via Firestore messages (which have their own
    // access rules). An attacker would need both the file path AND auth.
    //
    // Create: requires auth + image-specific size + content-type constraints.
    // Delete: restricted to the original uploader via custom metadata.
    //         The iOS client writes `uploaderId = request.auth.uid` at upload time.
    // Update: not permitted (metadata is set once at upload, never mutated).
    match /chat_media/{conversationId}/images/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidImage();
      allow delete: if isAuthenticated() && request.auth.uid == resource.metadata['uploaderId'];
    }

    // 3. Chat Documents
    // Same access model as chat images, but with document-specific constraints:
    // allowlisted MIME types (PDF, Word, OOXML, plain text) and 10 MB cap.
    match /chat_media/{conversationId}/docs/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidDocument();
      allow delete: if isAuthenticated() && request.auth.uid == resource.metadata['uploaderId'];
    }

    // Catch-all (Deny anything else not explicitly matched above)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
