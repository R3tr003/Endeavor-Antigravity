rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Check if the user is authenticated and verified via App Check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Ricava l'UUID Salesforce del richiedente dalla mappatura firebaseUid -> uuid.
    // Restituisce null se la mappatura non esiste ancora.
    function getUserUuid() {
      let mappingDoc = /databases/$(database)/documents/userMappings/$(request.auth.uid);
      return exists(mappingDoc) ? get(mappingDoc).data.uuid : null;
    }

    // Mappatura firebaseUid -> uuid (necessaria per le regole degli eventi).
    match /userMappings/{firebaseUid} {
      allow read: if isAuthenticated() && request.auth.uid == firebaseUid;
      allow create, update, delete: if false;
    }

    // Check if the incoming UserProfile data is structurally valid
    function isValidUser(data) {
      return data.size() >= 9
      && data.id is string
      && data.firstName is string && data.firstName.size() <= 50
      && data.lastName is string && data.lastName.size() <= 75
      && data.role is string && data.role.size() <= 50
      && data.email is string && data.email.size() <= 100
      && data.location is string && data.location.size() <= 100
      && data.timeZone is string && data.timeZone.size() <= 50
      && data.profileImageUrl is string
      && data.personalBio is string && data.personalBio.size() <= 1000
      && (!('userType' in data) || data.userType is string)
      && (!('nationality' in data) || data.nationality is string)
      && (!('languages' in data) || data.languages is list)
      && (!('phone' in data) || data.phone is string)
      && (!('createdAt' in data) || data.createdAt is timestamp)
      && (!('lastLoginAt' in data) || data.lastLoginAt is timestamp)
      && (!('icalToken' in data) || data.icalToken is string)
      && (!('icalTokenExpiry' in data) || data.icalTokenExpiry is timestamp);
    }
    
    // Check if the incoming CompanyProfile data is structurally valid
    function isValidCompany(data) {
      return data.size() >= 10
      && data.id is string
      && data.userId is string
      && data.name is string && data.name.size() <= 100
      && data.website is string && data.website.size() <= 100
      && data.hqCountry is string && data.hqCountry.size() <= 50
      && data.hqCity is string && data.hqCity.size() <= 50
      && data.stage is string && data.stage.size() <= 50
      && data.employeeRange is string && data.employeeRange.size() <= 50
      && data.companyBio is string && data.companyBio.size() <= 1000
      && data.industries is list && data.industries.size() <= 10
      && (!('challenges' in data) || (data.challenges is list && data.challenges.size() <= 3))
      && (!('desiredExpertise' in data) || (data.desiredExpertise is list && data.desiredExpertise.size() <= 10))
      && (!('logoUrl' in data) || data.logoUrl is string)
      && (!('vertical' in data) || data.vertical is string)
      && (!('endeavorChapter' in data) || data.endeavorChapter is string);
    }
    
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();
      
      // CREATE: Must match their Firebase Auth email, match UID as doc ID, and have valid data
      allow create: if isAuthenticated() 
                    && request.resource.data.email == request.auth.token.email
                    && isValidUser(request.resource.data);
      
      // UPDATE: Must already own this document AND keep their own email AND have valid data
      allow update: if isAuthenticated() 
                    && resource.data.email == request.auth.token.email
                    && isValidUser(request.resource.data);
      
      // DELETE
      allow delete: if isAuthenticated() 
                    && resource.data.email == request.auth.token.email;
    }
    
    match /events/{eventId} {
      allow read: if isAuthenticated()
                  && getUserUuid() in resource.data.participantIds;

      allow create: if isAuthenticated()
                    && getUserUuid() in request.resource.data.participantIds
                    && getUserUuid() == request.resource.data.createdBy;

      // Participants can update event fields, but:
      // - createdBy is immutable for everyone
      // - participantIds can only be changed by the creator
      allow update: if isAuthenticated()
                    && getUserUuid() in resource.data.participantIds
                    && request.resource.data.createdBy == resource.data.createdBy
                    && (request.resource.data.participantIds == resource.data.participantIds
                        || getUserUuid() == resource.data.createdBy);

      allow delete: if isAuthenticated()
                    && getUserUuid() == resource.data.createdBy;
    }

    match /companies/{companyId} {
      // Anyone authenticated can read company profiles
      allow read: if isAuthenticated();
      
      // CREATE, UPDATE: Must own the associated UserProfile document via backend Join and have valid data.
      // We use getAfter() instead of get() to support atomic batch writes for new users,
      // where the user document is created in the same batch.
      allow create, update: if isAuthenticated() 
                   && getAfter(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.email == request.auth.token.email
                   && isValidCompany(request.resource.data);
                   
      // DELETE: request.resource is null on delete, so we check `resource.data.userId` and use get()
      allow delete: if isAuthenticated()
                   && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.email == request.auth.token.email;
    }

    // Trigger documents written by the Cloud Function (checkMeetingCompletions) to signal
    // that a confirmed meeting has passed. The iOS app reads these on CalendarView open,
    // logs meeting_completed analytics client-side, then marks consumed: true.
    // Only Cloud Functions (admin SDK) can CREATE; users can only read/update their own.
    match /analytics_triggers/{docId} {
      allow read, update: if isAuthenticated()
                          && resource.data.userId == getUserUuid();
      allow create, delete: if false;
    }

    // Per-user rate limit counters written exclusively by Cloud Functions (admin SDK).
    // Users may read their own counters (e.g. to show remaining quota in the app),
    // but may NEVER write them — only the admin SDK bypasses these rules.
    match /rateLimits/{uid}/functions/{functionName} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
